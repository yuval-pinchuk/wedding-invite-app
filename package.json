{
  "name": "wedding-invite-app",
  "version": "1.0.0",
  "description": "Automated WhatsApp wedding invitation sender with RSVP landing page and Google Sheets tracking.",
  "main": "server/app.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node --max-old-space-size=300 server/app.js",
    "dev": "nodemon server/app.js",
    "debug": "node --inspect server/app.js",
    "debug-brk": "node --inspect-brk server/app.js",
    "send:invitations": "node scripts/sendInvitations.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "googleapis": "^131.0.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "nodemon": "^3.1.4"
  }
}
